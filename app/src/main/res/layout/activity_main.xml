<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#f0f8ff">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌐 স্মার্ট ব্রাউজার মনিটর"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:textColor="#2c3e50" />
    <Button
        android:id="@+id/permission_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grant Usage Permission"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#FF9800"
        android:textColor="@android:color/white" />
    <!-- Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="16dp"
        android:elevation="4dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="প্রস্তুত"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#27ae60"
            android:padding="8dp" />

        <TextView
            android:id="@+id/current_app_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="কোন অ্যাপ চালু নেই"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/timer_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:textColor="#e74c3c" />

    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/start_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="শুরু করুন"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#27ae60"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/stop_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="বন্ধ করুন"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#e74c3c"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/reset_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="রিসেট"
            android:layout_marginStart="8dp"
            android:backgroundTint="#f39c12"
            android:textColor="@android:color/white" />

    </LinearLayout>

    <!-- Logs Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="লগ সমূহ:"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:textColor="#2c3e50" />

    <!-- Logs List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/log_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:padding="8dp" />

    <!-- Footer Info -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ℹ️ ১০ মিনিট ব্যবহার = ১ ঘন্টা ব্লক"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:textColor="#7f8c8d" />

</LinearLayout>